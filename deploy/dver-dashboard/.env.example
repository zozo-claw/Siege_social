# GitHub OAuth App credentials (create at https://github.com/settings/developers)
OAUTH2_PROXY_CLIENT_ID=your_github_oauth_app_client_id
OAUTH2_PROXY_CLIENT_SECRET=your_github_oauth_app_client_secret

# Generate with: python3 -c "import secrets; print(secrets.token_hex(16))"
OAUTH2_PROXY_COOKIE_SECRET=your_32char_random_secret
